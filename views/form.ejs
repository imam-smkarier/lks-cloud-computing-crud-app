<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tambah Data — LKS Cloud Computing</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', system-ui, sans-serif; background: #f8fafc; color: #1e293b; min-height: 100vh; }
    .header { background: linear-gradient(135deg, #06453f 0%, #149a94 100%); color: white; padding: 24px 32px; }
    .header h1 { font-size: 20px; font-weight: 700; }
    .header p { font-size: 12px; opacity: 0.8; margin-top: 4px; }
    .container { max-width: 500px; margin: 24px auto; padding: 0 16px; }
    .card { background: white; border-radius: 8px; border: 1px solid #e2e8f0; padding: 24px; }
    .card h2 { font-size: 16px; color: #06453f; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 2px solid #149a94; }
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 13px; font-weight: 600; color: #475569; margin-bottom: 6px; }
    .form-group input { width: 100%; padding: 10px 14px; border: 1px solid #e2e8f0; border-radius: 6px; font-size: 14px; transition: border 0.2s; }
    .form-group input:focus { outline: none; border-color: #149a94; box-shadow: 0 0 0 3px rgba(20,154,148,0.1); }
    .btn { display: inline-block; padding: 10px 20px; border-radius: 6px; text-decoration: none; font-size: 14px; font-weight: 600; border: none; cursor: pointer; transition: all 0.2s; }
    .btn-primary { background: #06453f; color: white; }
    .btn-primary:hover { background: #149a94; }
    .btn-back { background: #f1f5f9; color: #475569; margin-left: 8px; }
    .btn-back:hover { background: #e2e8f0; }
    .actions { margin-top: 20px; display: flex; align-items: center; }
  </style>
</head>
<body>
  <div class="header">
    <h1>📋 LKS Cloud Computing — Kabupaten Bogor 2026</h1>
    <p>Aplikasi CRUD | Penyelenggara: KCD - Wilayah I Provinsi Jawa Barat | Sponsored by PT SMKarier Inovasi Digital</p>
  </div>
  <div class="container">
    <div class="card">
      <h2>Tambah Data Baru</h2>
      <form action="/add" method="POST">
        <div class="form-group">
          <label for="name">Nama Lengkap</label>
          <input type="text" id="name" name="name" placeholder="Masukkan nama lengkap" required>
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="contoh@email.com" required>
        </div>
        <div class="actions">
          <button type="submit" class="btn btn-primary">💾 Simpan</button>
          <a href="/" class="btn btn-back">← Kembali</a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
